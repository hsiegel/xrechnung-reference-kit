#*
  Composed draft invoice template.

  This file shows the intended long-term shape of an invoice template:
  a thin document shell plus embedded reusable macros in a single uploadable file.

  Scope:
  - UBL Invoice
  - XRechnung 3.0.2 semantic block tree
  - draft-tolerant rendering, not final business validation
  - self-contained: no external #parse dependency at runtime
*#

#*
  Embedded macro set derived from templates/ubl-pattern-library.vm.

  Assumptions:
  - Root model object is named $xr
  - Helper object is named $xrh
  - $xrh.has(value) treats numeric zero as present and blank strings as absent
*#

#macro(xrText $tag $value)
#if($xrh.has($value))
<$tag>$xrh.text($value)</$tag>
#end
#end

#macro(xrDate $tag $value)
#if($xrh.has($value))
<$tag>$xrh.date($value)</$tag>
#end
#end

#macro(xrNumber $tag $value)
#if($xrh.has($value))
<$tag>$xrh.number($value)</$tag>
#end
#end

#macro(xrNamedCode $tag $value $nameValue)
#if($xrh.has($value))
<$tag#if($xrh.has($nameValue)) name="$xrh.attr($nameValue)"#end>$xrh.text($value)</$tag>
#end
#end

#macro(xrAmount $tag $value $currency)
#if($xrh.has($value))
<$tag#if($xrh.has($currency)) currencyID="$xrh.attr($currency)"#end>$xrh.amount($value)</$tag>
#end
#end

#macro(xrQuantity $tag $value $unitCode)
#if($xrh.has($value))
<$tag#if($xrh.has($unitCode)) unitCode="$xrh.attr($unitCode)"#end>$xrh.number($value)</$tag>
#end
#end

#macro(xrIdentifier $tag $value $schemeId)
#if($xrh.has($value))
<$tag#if($xrh.has($schemeId)) schemeID="$xrh.attr($schemeId)"#end>$xrh.text($value)</$tag>
#end
#end

#macro(xrNote $tag $note)
#set($xrNoteText = $note.text)
#set($xrSubjectCode = $note.subjectCode)
#if($xrh.has($xrNoteText))
  #if($xrh.has($xrSubjectCode))
    #set($xrHash = '#')
<$tag>$xrHash$xrh.text($xrSubjectCode)$xrHash$xrh.text($xrNoteText)</$tag>
  #else
<$tag>$xrh.text($xrNoteText)</$tag>
  #end
#end
#end

#macro(xrProjectReference $projectReferenceId)
#if($xrh.has($projectReferenceId))
<cac:ProjectReference>
  #xrText("cbc:ID" $projectReferenceId)
</cac:ProjectReference>
#end
#end

#macro(xrDocumentReference $wrapperTag $id)
#if($xrh.has($id))
<$wrapperTag>
