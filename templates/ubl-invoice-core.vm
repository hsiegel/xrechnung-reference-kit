#*
  Draft Velocity core template for a public XRechnung-shaped model.

  Assumptions:
  - Root object in context: $xr
  - Helper object in context: $xrh
  - $xrh.has(value): boolean
    Important: numeric zero counts as present, blank strings count as absent
  - $xrh.text(value): XML-escaped text
  - $xrh.attr(value): XML-escaped attribute value
  - $xrh.date(value): formatted as yyyy-MM-dd
  - $xrh.amount(value): decimal string for amount values
  - $xrh.number(value): decimal string for quantity and percentage values

  Scope:
  - This template mirrors the first public core slice from
    public-model/ubl-invoice-core-mapping.yaml
  - Internal DTOs are intentionally out of scope
  - Totals and VAT breakdowns are assumed to be prepared before rendering
  - Rendering is draft-tolerant: missing business values do not abort rendering
    and are omitted from the XML output
  - This file is self-contained and embeds its required render macros directly
  - templates/ubl-pattern-library.vm remains only as a reference source for the
    embedded macro block below
  - The core cut is defined by the top-level groups used here; within those
    groups the shared macros may also render optional child values when present
*#

#*
  Embedded macro set derived from templates/ubl-pattern-library.vm.

  Assumptions:
  - Root model object is named $xr
  - Helper object is named $xrh
  - $xrh.has(value) treats numeric zero as present and blank strings as absent
*#

#macro(xrText $tag $value)
#if($xrh.has($value))
<$tag>$xrh.text($value)</$tag>
#end
#end

#macro(xrDate $tag $value)
#if($xrh.has($value))
<$tag>$xrh.date($value)</$tag>
#end
#end

#macro(xrNumber $tag $value)
#if($xrh.has($value))
<$tag>$xrh.number($value)</$tag>
#end
#end

#macro(xrNamedCode $tag $value $nameValue)
#if($xrh.has($value))
<$tag#if($xrh.has($nameValue)) name="$xrh.attr($nameValue)"#end>$xrh.text($value)</$tag>
#end
#end

#macro(xrAmount $tag $value $currency)
#if($xrh.has($value))
<$tag#if($xrh.has($currency)) currencyID="$xrh.attr($currency)"#end>$xrh.amount($value)</$tag>
#end
#end

#macro(xrQuantity $tag $value $unitCode)
#if($xrh.has($value))
<$tag#if($xrh.has($unitCode)) unitCode="$xrh.attr($unitCode)"#end>$xrh.number($value)</$tag>
#end
#end

#macro(xrIdentifier $tag $value $schemeId)
#if($xrh.has($value))
<$tag#if($xrh.has($schemeId)) schemeID="$xrh.attr($schemeId)"#end>$xrh.text($value)</$tag>
#end
#end

#macro(xrLineObjectReference $ref)
#set($xrHasLineObjectReference = $xrh.has($ref.id))
#if($xrHasLineObjectReference)
<cac:DocumentReference>
  #xrIdentifier("cbc:ID" $ref.id $ref.schemeId)
  <cbc:DocumentTypeCode>130</cbc:DocumentTypeCode>
</cac:DocumentReference>
#end
#end

#macro(xrInvoicePeriod $period)
#set($xrHasPeriod = $xrh.has($period.startDate) || $xrh.has($period.endDate) || $xrh.has($period.descriptionCode))
#if($xrHasPeriod)
<cac:InvoicePeriod>
  #xrDate("cbc:StartDate" $period.startDate)
  #xrDate("cbc:EndDate" $period.endDate)
  #xrText("cbc:DescriptionCode" $period.descriptionCode)
</cac:InvoicePeriod>
#end
#end

#macro(xrAddress $wrapperTag $address)
#set($xrAddressLine = "")
#if($xrh.has($address.addressLine))
  #set($xrAddressLine = $address.addressLine)
#end
#set($xrHasAddress = $xrh.has($address.street) || $xrh.has($address.additionalStreet) || $xrh.has($xrAddressLine) || $xrh.has($address.city) || $xrh.has($address.postalCode) || $xrh.has($address.countrySubdivision) || $xrh.has($address.countryCode))
#if($xrHasAddress)
<$wrapperTag>
  #xrText("cbc:StreetName" $address.street)
  #xrText("cbc:AdditionalStreetName" $address.additionalStreet)
  #xrText("cbc:CityName" $address.city)
  #xrText("cbc:PostalZone" $address.postalCode)
  #xrText("cbc:CountrySubentity" $address.countrySubdivision)
  #if($xrh.has($xrAddressLine))
  <cac:AddressLine>
    #xrText("cbc:Line" $xrAddressLine)
  </cac:AddressLine>
  #end
  #if($xrh.has($address.countryCode))
  <cac:Country>
    #xrText("cbc:IdentificationCode" $address.countryCode)
  </cac:Country>
  #end
</$wrapperTag>
#end
#end

#macro(xrPostalAddress $address)
#xrAddress("cac:PostalAddress" $address)
#end

#macro(xrContact $contact)
#set($xrHasContact = $xrh.has($contact.name) || $xrh.has($contact.phone) || $xrh.has($contact.email))
#if($xrHasContact)
<cac:Contact>
  #xrText("cbc:Name" $contact.name)
  #xrText("cbc:Telephone" $contact.phone)
  #xrText("cbc:ElectronicMail" $contact.email)
</cac:Contact>
#end
#end

#macro(xrNestedParty $wrapperTag $party)
#set($xrHasParty = $xrh.has($party.name) || $xrh.has($party.tradeName) || $xrh.has($party.endpoint.value) || $xrh.has($party.identifiers) || $xrh.has($party.sepaCreditorId) || $xrh.has($party.vatIdentifier) || $xrh.has($party.taxIdentifier) || $xrh.has($party.legalRegistrationId) || $xrh.has($party.legalForm) || $xrh.has($party.address) || $xrh.has($party.contact))
#if($xrHasParty)
<$wrapperTag>
  <cac:Party>
    #xrIdentifier("cbc:EndpointID" $party.endpoint.value $party.endpoint.schemeId)
    #if($xrh.has($party.sepaCreditorId))
    <cac:PartyIdentification>
      <cbc:ID schemeID="SEPA">$xrh.text($party.sepaCreditorId)</cbc:ID>
    </cac:PartyIdentification>
    #end
    #if($xrh.has($party.identifiers))
      #foreach($identifier in $party.identifiers)
        #if($xrh.has($identifier.value))
    <cac:PartyIdentification>
      #xrIdentifier("cbc:ID" $identifier.value $identifier.schemeId)
    </cac:PartyIdentification>
        #end
      #end
    #end
    #xrPostalAddress($party.address)
    #if($xrh.has($party.vatIdentifier))
    <cac:PartyTaxScheme>
      #xrText("cbc:CompanyID" $party.vatIdentifier)
      <cac:TaxScheme>
        <cbc:ID>VAT</cbc:ID>
      </cac:TaxScheme>
    </cac:PartyTaxScheme>
    #end
    #if($xrh.has($party.taxIdentifier))
    <cac:PartyTaxScheme>
      #xrText("cbc:CompanyID" $party.taxIdentifier)
      <cac:TaxScheme>
        <cbc:ID>TAX</cbc:ID>
      </cac:TaxScheme>
    </cac:PartyTaxScheme>
    #end
    #if($xrh.has($party.tradeName))
    <cac:PartyName>
      #xrText("cbc:Name" $party.tradeName)
    </cac:PartyName>
    #end
    #if($xrh.has($party.name) || $xrh.has($party.legalRegistrationId) || $xrh.has($party.legalForm))
    <cac:PartyLegalEntity>
      #xrText("cbc:RegistrationName" $party.name)
      #xrIdentifier("cbc:CompanyID" $party.legalRegistrationId $party.legalRegistrationIdSchemeId)
      #xrText("cbc:CompanyLegalForm" $party.legalForm)
    </cac:PartyLegalEntity>
    #end
    #xrContact($party.contact)
  </cac:Party>
</$wrapperTag>
#end
#end

#macro(xrPaymentMeans $payment)
#set($xrHasPayment = $xrh.has($payment.meansCode) || $xrh.has($payment.meansText) || $xrh.has($payment.paymentId) || $xrh.has($payment.payeeAccounts) || $xrh.has($payment.cards) || $xrh.has($payment.mandates))
#if($xrHasPayment)
<cac:PaymentMeans>
  #xrNamedCode("cbc:PaymentMeansCode" $payment.meansCode $payment.meansText)
  #xrText("cbc:PaymentID" $payment.paymentId)
  #if($xrh.has($payment.payeeAccounts))
    #foreach($account in $payment.payeeAccounts)
      #if($xrh.has($account.id) || $xrh.has($account.name) || $xrh.has($account.bic))
  <cac:PayeeFinancialAccount>
    #xrText("cbc:ID" $account.id)
    #xrText("cbc:Name" $account.name)
    #if($xrh.has($account.bic))
    <cac:FinancialInstitutionBranch>
      #xrText("cbc:ID" $account.bic)
    </cac:FinancialInstitutionBranch>
    #end
  </cac:PayeeFinancialAccount>
      #end
    #end
  #end
  #if($xrh.has($payment.cards))
    #foreach($card in $payment.cards)
      #if($xrh.has($card.primaryAccountNumberId) || $xrh.has($card.holderName))
  <cac:CardAccount>
    #xrText("cbc:PrimaryAccountNumberID" $card.primaryAccountNumberId)
    #xrText("cbc:HolderName" $card.holderName)
  </cac:CardAccount>
      #end
    #end
  #end
  #if($xrh.has($payment.mandates))
    #foreach($mandate in $payment.mandates)
      #if($xrh.has($mandate.id) || $xrh.has($mandate.payerAccountId))
  <cac:PaymentMandate>
    #xrText("cbc:ID" $mandate.id)
    #if($xrh.has($mandate.payerAccountId))
    <cac:PayerFinancialAccount>
      #xrText("cbc:ID" $mandate.payerAccountId)
    </cac:PayerFinancialAccount>
    #end
  </cac:PaymentMandate>
      #end
    #end
  #end
</cac:PaymentMeans>
#end
#end

#macro(xrTaxCategory $wrapperTag $tax)
#set($xrHasTax = $xrh.has($tax.categoryCode) || $xrh.has($tax.rate) || $xrh.has($tax.exemptionReason) || $xrh.has($tax.exemptionReasonCode))
#if($xrHasTax)
<$wrapperTag>
  #xrText("cbc:ID" $tax.categoryCode)
  #xrNumber("cbc:Percent" $tax.rate)
  #xrText("cbc:TaxExemptionReason" $tax.exemptionReason)
  #xrText("cbc:TaxExemptionReasonCode" $tax.exemptionReasonCode)
  <cac:TaxScheme>
    <cbc:ID>VAT</cbc:ID>
  </cac:TaxScheme>
</$wrapperTag>
#end
#end

#macro(xrAllowanceCharge $entry $chargeIndicator $currency)
#set($xrHasAllowance = $xrh.has($entry.amount) || $xrh.has($entry.baseAmount) || $xrh.has($entry.percent) || $xrh.has($entry.reason) || $xrh.has($entry.reasonCode) || $xrh.has($entry.tax))
#if($xrHasAllowance)
<cac:AllowanceCharge>
  <cbc:ChargeIndicator>$chargeIndicator</cbc:ChargeIndicator>
  #xrAmount("cbc:Amount" $entry.amount $currency)
  #xrAmount("cbc:BaseAmount" $entry.baseAmount $currency)
  #xrNumber("cbc:MultiplierFactorNumeric" $entry.percent)
  #xrText("cbc:AllowanceChargeReason" $entry.reason)
  #xrText("cbc:AllowanceChargeReasonCode" $entry.reasonCode)
  #xrTaxCategory("cac:TaxCategory" $entry.tax)
</cac:AllowanceCharge>
#end
#end

#macro(xrTaxSubtotal $vat $currency)
#set($xrHasTaxSubtotal = $xrh.has($vat.taxableAmount) || $xrh.has($vat.taxAmount) || $xrh.has($vat.categoryCode) || $xrh.has($vat.rate) || $xrh.has($vat.exemptionReason) || $xrh.has($vat.exemptionReasonCode))
#if($xrHasTaxSubtotal)
<cac:TaxSubtotal>
  #xrAmount("cbc:TaxableAmount" $vat.taxableAmount $currency)
  #xrAmount("cbc:TaxAmount" $vat.taxAmount $currency)
  #xrTaxCategory("cac:TaxCategory" $vat)
</cac:TaxSubtotal>
#end
#end

#macro(xrTaxTotal $documentTaxAmount $accountingTaxAmount $vatBreakdowns $documentCurrency $taxCurrency)
#if($xrh.has($documentTaxAmount) || $xrh.has($accountingTaxAmount) || $xrh.has($vatBreakdowns))
<cac:TaxTotal>
  #xrAmount("cbc:TaxAmount" $documentTaxAmount $documentCurrency)
  #xrAmount("cbc:TaxAmount" $accountingTaxAmount $taxCurrency)
  #if($xrh.has($vatBreakdowns))
    #foreach($vat in $vatBreakdowns)
      #xrTaxSubtotal($vat $documentCurrency)
    #end
  #end
</cac:TaxTotal>
#end
#end

#macro(xrMonetaryTotal $totals $currency)
#set($xrHasMonetaryTotal = $xrh.has($totals.lineExtensionAmount) || $xrh.has($totals.allowanceTotalAmount) || $xrh.has($totals.chargeTotalAmount) || $xrh.has($totals.taxExclusiveAmount) || $xrh.has($totals.taxInclusiveAmount) || $xrh.has($totals.prepaidAmount) || $xrh.has($totals.payableRoundingAmount) || $xrh.has($totals.payableAmount))
#if($xrHasMonetaryTotal)
<cac:LegalMonetaryTotal>
  #xrAmount("cbc:LineExtensionAmount" $totals.lineExtensionAmount $currency)
  #xrAmount("cbc:AllowanceTotalAmount" $totals.allowanceTotalAmount $currency)
  #xrAmount("cbc:ChargeTotalAmount" $totals.chargeTotalAmount $currency)
  #xrAmount("cbc:TaxExclusiveAmount" $totals.taxExclusiveAmount $currency)
  #xrAmount("cbc:TaxInclusiveAmount" $totals.taxInclusiveAmount $currency)
  #xrAmount("cbc:PrepaidAmount" $totals.prepaidAmount $currency)
  #xrAmount("cbc:PayableRoundingAmount" $totals.payableRoundingAmount $currency)
  #xrAmount("cbc:PayableAmount" $totals.payableAmount $currency)
</cac:LegalMonetaryTotal>
#end
#end

#macro(xrPriceDiscount $discount $currency)
#set($xrHasPriceDiscount = $xrh.has($discount.amount) || $xrh.has($discount.baseAmount))
#if($xrHasPriceDiscount)
<cac:AllowanceCharge>
  <cbc:ChargeIndicator>false</cbc:ChargeIndicator>
  #xrAmount("cbc:Amount" $discount.amount $currency)
  #xrAmount("cbc:BaseAmount" $discount.baseAmount $currency)
</cac:AllowanceCharge>
#end
#end

#macro(xrPrice $price $currency)
#set($xrHasPrice = $xrh.has($price.netAmount) || $xrh.has($price.discount) || $xrh.has($price.baseQuantity))
#if($xrHasPrice)
<cac:Price>
  #xrAmount("cbc:PriceAmount" $price.netAmount $currency)
  #xrPriceDiscount($price.discount $currency)
  #xrQuantity("cbc:BaseQuantity" $price.baseQuantity $price.baseQuantityUnitCode)
</cac:Price>
#end
#end

#macro(xrItem $item $tax)
#set($xrHasItem = $xrh.has($item.description) || $xrh.has($item.name) || $xrh.has($item.sellersItemId) || $xrh.has($item.buyersItemId) || $xrh.has($item.standardId) || $xrh.has($item.classifications) || $xrh.has($item.originCountryCode) || $xrh.has($item.attributes) || $xrh.has($tax))
#if($xrHasItem)
<cac:Item>
  #xrText("cbc:Description" $item.description)
  #xrText("cbc:Name" $item.name)
  #if($xrh.has($item.sellersItemId))
  <cac:SellersItemIdentification>
    #xrText("cbc:ID" $item.sellersItemId)
  </cac:SellersItemIdentification>
  #end
  #if($xrh.has($item.buyersItemId))
  <cac:BuyersItemIdentification>
    #xrText("cbc:ID" $item.buyersItemId)
  </cac:BuyersItemIdentification>
  #end
  #if($xrh.has($item.standardId))
  <cac:StandardItemIdentification>
    #xrIdentifier("cbc:ID" $item.standardId $item.standardIdSchemeId)
  </cac:StandardItemIdentification>
  #end
  #if($xrh.has($item.classifications))
    #foreach($classification in $item.classifications)
      #if($xrh.has($classification.code))
  <cac:CommodityClassification>
    <cbc:ItemClassificationCode#if($xrh.has($classification.listId)) listID="$xrh.attr($classification.listId)"#end#if($xrh.has($classification.listVersionId)) listVersionID="$xrh.attr($classification.listVersionId)"#end>$xrh.text($classification.code)</cbc:ItemClassificationCode>
  </cac:CommodityClassification>
      #end
    #end
  #end
  #if($xrh.has($item.originCountryCode))
  <cac:OriginCountry>
    #xrText("cbc:IdentificationCode" $item.originCountryCode)
  </cac:OriginCountry>
  #end
  #if($xrh.has($item.attributes))
    #foreach($attribute in $item.attributes)
      #if($xrh.has($attribute.name) || $xrh.has($attribute.value))
  <cac:AdditionalItemProperty>
    #xrText("cbc:Name" $attribute.name)
    #xrText("cbc:Value" $attribute.value)
  </cac:AdditionalItemProperty>
      #end
    #end
  #end
  #xrTaxCategory("cac:ClassifiedTaxCategory" $tax)
</cac:Item>
#end
#end

#macro(xrInvoiceLine $line $currency)
#set($xrHasLine = $xrh.has($line.id) || $xrh.has($line.note) || $xrh.has($line.objectReference) || $xrh.has($line.quantity) || $xrh.has($line.lineExtensionAmount) || $xrh.has($line.accountingCost) || $xrh.has($line.orderLineReference) || $xrh.has($line.period) || $xrh.has($line.allowances) || $xrh.has($line.charges) || $xrh.has($line.item) || $xrh.has($line.vat) || $xrh.has($line.price))
#if($xrHasLine)
<cac:InvoiceLine>
  #xrText("cbc:ID" $line.id)
  #xrText("cbc:Note" $line.note)
  #xrQuantity("cbc:InvoicedQuantity" $line.quantity $line.quantityUnitCode)
  #xrAmount("cbc:LineExtensionAmount" $line.lineExtensionAmount $currency)
  #xrText("cbc:AccountingCost" $line.accountingCost)
  #xrInvoicePeriod($line.period)
  #if($xrh.has($line.orderLineReference))
  <cac:OrderLineReference>
    #xrText("cbc:LineID" $line.orderLineReference)
  </cac:OrderLineReference>
  #end
  #xrLineObjectReference($line.objectReference)
  #if($xrh.has($line.allowances))
    #foreach($allowance in $line.allowances)
      #xrAllowanceCharge($allowance "false" $currency)
    #end
  #end
  #if($xrh.has($line.charges))
    #foreach($charge in $line.charges)
      #xrAllowanceCharge($charge "true" $currency)
    #end
  #end
  #xrItem($line.item $line.vat)
  #xrPrice($line.price $currency)
</cac:InvoiceLine>
#end
#end
#set($currency = $xr.invoice.documentCurrencyCode)
<?xml version="1.0" encoding="UTF-8"?>
<Invoice
  xmlns="urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
  xmlns:cac="urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2"
  xmlns:cec="urn:oasis:names:specification:ubl:schema:xsd:CommonExtensionComponents-2"
  xmlns:cbc="urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2">
  ## BG-2 process control
  #xrText("cbc:CustomizationID" $xr.process.customizationId)
  #xrText("cbc:ProfileID" $xr.process.profileId)

  ## Invoice header core
  #xrText("cbc:ID" $xr.invoice.id)
  #xrDate("cbc:IssueDate" $xr.invoice.issueDate)
  #xrText("cbc:InvoiceTypeCode" $xr.invoice.typeCode)
  #xrText("cbc:DocumentCurrencyCode" $xr.invoice.documentCurrencyCode)
  #xrText("cbc:BuyerReference" $xr.invoice.buyerReference)

  ## BG-4 seller
  #xrNestedParty("cac:AccountingSupplierParty" $xr.seller)

  ## BG-7 buyer
  #xrNestedParty("cac:AccountingCustomerParty" $xr.buyer)

  ## BG-16 payment instructions
  #xrPaymentMeans($xr.payment)

  ## Synthetic UBL wrapper for BT-110 and BG-23
  #xrTaxTotal($xr.totals.taxAmountInDocumentCurrency "" $xr.vatBreakdowns $currency "")

  ## BG-22 document totals
  #xrMonetaryTotal($xr.totals $currency)

  ## BG-25 invoice lines
  #if($xrh.has($xr.lines))
    #foreach($line in $xr.lines)
      #xrInvoiceLine($line $currency)
    #end
  #end
</Invoice>
